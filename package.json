{
  "name": "cto-app",
  "version": "0.1.0",
  "private": true,
  "description": "CTO — Tauri shell + React UI",
  "license": "MIT",
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "dev": "npm --workspace ui run dev",
    "web:dev": "npm --workspace ui run web:dev",
    "web:init:dev": "npm --workspace ui run web:init:dev",
    "web:preview": "npm --workspace ui run web:preview",
    "build": "npm --workspace ui run build",
    "preview": "npm --workspace ui run preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "e2e:tauri": "mocha e2e/tauri/**/*.e2e.mjs",
    "e2e:local-stack-cycle": "node scripts/e2e/local-stack-cycle.mjs",
    "e2e:local-stack-intent": "CTO_E2E_INTENT_TEST=1 node scripts/e2e/local-stack-cycle.mjs --reset",
    "e2e:local-stack-clean-slate": "node scripts/e2e/clean-slate-cycle.mjs",
    "e2e:k8s-smoke": "node scripts/e2e/kind-platform-smoke.mjs",
    "mcp:tauri": "node ./node_modules/tauri-plugin-mcp-server/build/index.js",
    "mcp:scenario": "node scripts/mcp-scenario-server.mjs",
    "scenario:morgan-videos": "node scripts/generate-morgan-scenario-videos.mjs",
    "icons:openclaw-svgs": "node scripts/sync-openclaw-provider-svgs.mjs"
  },
  "devDependencies": {
    "@scenario-labs/sdk": "^1.2.0",
    "@tauri-apps/cli": "^2.1.0",
    "chai": "^5.2.1",
    "mocha": "^11.7.1",
    "selenium-webdriver": "^4.34.0",
    "tauri-plugin-mcp-server": "^0.1.0"
  }
}
