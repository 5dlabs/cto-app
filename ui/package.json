{
  "name": "cto-app-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "web:dev": "VITE_CTO_SKIP_LOCAL_STACK_BOOTSTRAP=1 vite --host localhost --port 5173 --strictPort=false",
    "web:init:dev": "VITE_CTO_INIT_PREVIEW=1 VITE_CTO_FORCE_LOCAL_STACK_BOOTSTRAP=1 vite --host localhost --port 5174 --strictPort=false",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "web:preview": "VITE_CTO_SKIP_LOCAL_STACK_BOOTSTRAP=1 vite preview --host localhost --port 4173 --strictPort=false",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tauri-plugin-mcp": "^0.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
