{
  "id": "nats-messenger",
  "name": "NATS Messenger",
  "version": "1.1.0",
  "description": "Inter-agent messaging over NATS for cross-pod communication",
  "author": "5dlabs",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "url": { "type": "string", "default": "nats://nats.messaging.svc.cluster.local:4222" },
      "agentName": { "type": "string" },
      "subjects": {
        "type": "array",
        "items": { "type": "string" }
      },
      "reconnectWaitMs": { "type": "number", "default": 2000 },
      "maxReconnectAttempts": { "type": "number", "default": -1 },
      "agentRole": { "type": "string", "default": "general" },
      "roster": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "role": { "type": "string" }
          },
          "required": ["id", "role"]
        },
        "default": []
      },
      "maxPingPongTurns": { "type": "number", "default": 10 },
      "pingPongWindowMs": { "type": "number", "default": 300000 }
    },
    "required": ["url", "agentName"]
  },
  "uiHints": {
    "category": "messaging",
    "icon": "message-square"
  }
}
