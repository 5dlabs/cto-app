{
  "name": "morgan-setup",
  "version": 1,
  "screens": [
    {
      "id": "saved-access",
      "checkpoint": "02-saved-access",
      "heading": "Saved access",
      "docs": "docs/intent/morgan-setup/saved-access.md",
      "requiredText": [],
      "requiredControls": [
        "Use 1Password for secrets",
        "Use Bitwarden for secrets",
        "Continue without saved access",
        "Continue to Cloudflare"
      ],
      "inputs": [
        "savedAccessPrepMode",
        "secretSource",
        "secretSourceProvider",
        "secretRefs"
      ],
      "payloadPaths": [
        "secretSources",
        "secretRefs"
      ],
      "rules": [
        "optional-secret-source",
        "manual-fallback-visible",
        "secrets-redacted",
        "approval-required",
        "morgan-narrated",
        "icon-first"
      ],
      "secretSources": [
        {
          "id": "onepassword",
          "label": "1Password",
          "availability": "sdk-connect",
          "tier": "free-local",
          "rawSecretAccess": false,
          "backend": "sdk",
          "requiresCli": false,
          "priority": "peer",
          "firstView": true,
          "sdk": {
            "package": "@1password/sdk",
            "auth": [
              "OP_SERVICE_ACCOUNT_TOKEN",
              "OP_ACCOUNT"
            ],
            "metadataPreview": "client.items.list(vault)",
            "approvedRead": "client.items.get(itemId)"
          },
          "safetyNotes": [
            "Do not require the op CLI by default; use SDK auth or official 1Password SDK guidance.",
            "Do not read secret values before approval; preview metadata and redacted target matches only.",
            "Do not display, log, or persist item fields; values may exist only in memory during approved apply."
          ]
        },
        {
          "id": "bitwarden",
          "label": "Bitwarden",
          "availability": "sdk-connect",
          "tier": "pro-team",
          "priority": "peer",
          "firstView": true,
          "rawSecretAccess": false,
          "safetyNotes": [
            "Do not ask for a Bitwarden master password; use Secrets Manager SDK auth only.",
            "Do not require the bw CLI for default setup.",
            "Do not read secret values before approval; preview metadata and redacted target matches only.",
            "Do not display, log, or persist secret fields; values may exist only in memory during approved apply."
          ],
          "backend": "sdk",
          "requiresCli": false,
          "sdk": {
            "package": "@bitwarden/sdk-napi",
            "auth": [
              "BWS_ACCESS_TOKEN",
              "organizationId"
            ],
            "metadataPreview": "client.secrets().list(organizationId)",
            "approvedRead": "client.secrets().get(secretId)"
          }
        },
        {
          "id": "lastpass",
          "label": "LastPass",
          "availability": "more-options",
          "tier": "pro-team",
          "rawSecretAccess": false
        },
        {
          "id": "keeper",
          "label": "Keeper",
          "availability": "more-options",
          "tier": "pro-team",
          "rawSecretAccess": false
        },
        {
          "id": "doppler",
          "label": "Doppler",
          "availability": "more-options",
          "tier": "pro-team",
          "rawSecretAccess": false
        },
        {
          "id": "infisical",
          "label": "Infisical",
          "availability": "more-options",
          "tier": "pro-team",
          "rawSecretAccess": false
        }
      ],
      "quickConnect": {
        "provider": "onepassword",
        "apis": [
          "detect_secret_sources",
          "preview_secret_source_matches",
          "apply_secret_source_matches"
        ],
        "discovery": "metadata-only",
        "approvalRequired": true,
        "targets": [
          "GITHUB_TOKEN",
          "GITLAB_TOKEN",
          "OPENAI_API_KEY",
          "OPENROUTER_API_KEY",
          "EXA_API_KEY",
          "FIRECRAWL_API_KEY",
          "TAVILY_API_KEY",
          "DISCORD_BOT_TOKEN"
        ],
        "providers": [
          "onepassword",
          "bitwarden"
        ]
      },
      "mediaFolder": "02_saved-access",
      "conditionalMedia": [
        "onepassword-ready",
        "onepassword-missing-desktop",
        "onepassword-missing-cli",
        "onepassword-desktop-integration",
        "onepassword-needs-access",
        "onepassword-no-account",
        "bitwarden-detected",
        "bitwarden-locked",
        "bitwarden-unlocked"
      ]
    },
    {
      "id": "endpoint",
      "checkpoint": "03-endpoint",
      "heading": "Cloudflare",
      "docs": "docs/intent/morgan-setup/endpoint.md",
      "mediaFolder": "03_endpoint",
      "requiredText": [],
      "requiredControls": [
        "Sign in with Cloudflare",
        "Find Cloudflare access in 1Password",
        "Use a temporary Cloudflare tunnel",
        "Continue to Source"
      ],
      "inputs": [
        "endpointMode",
        "endpointUrl"
      ],
      "payloadPaths": [
        "source.webhookBaseUrl",
        "source.webhookMode"
      ],
      "rules": [
        "optional-public-endpoint",
        "official-brand-icons",
        "morgan-narrated",
        "cloudflare-saved-access-conditional-media"
      ],
      "conditionalMedia": [
        "cloudflare-login",
        "cloudflare-saved-access",
        "cloudflare-quick-tunnel",
        "cloudflare-local"
      ]
    },
    {
      "id": "source",
      "checkpoint": "04-source-configured",
      "heading": "Source",
      "docs": "docs/intent/morgan-setup/source-auth-matrix.md",
      "requiredText": [
        "GitHub",
        "GitLab"
      ],
      "requiredControls": [
        "GitHub",
        "GitLab",
        "Find my access",
        "Paste token",
        "Continue to harness selection"
      ],
      "inputs": [
        "provider",
        "hostMode",
        "baseUrl",
        "owner",
        "repository",
        "token"
      ],
      "payloadPaths": [
        "source.provider",
        "source.baseUrl",
        "source.owner",
        "source.connectionId"
      ],
      "rules": [
        "continue-disabled-until-authorized",
        "secrets-redacted"
      ],
      "authMatrix": [
        {
          "id": "github-oauth",
          "provider": "github",
          "host": "github.com",
          "auth": "oauth",
          "mustExpose": [
            "Authorize with GitHub",
            "device-code prompt boundary"
          ],
          "mustRedact": [
            "github token",
            "device code"
          ]
        },
        {
          "id": "github-pat",
          "provider": "github",
          "host": "github.com",
          "auth": "manual-token",
          "mustExpose": [
            "GitHub PAT password input"
          ],
          "mustRedact": [
            "github_pat value"
          ]
        },
        {
          "id": "github-enterprise",
          "provider": "github",
          "host": "custom",
          "auth": "github-app-manifest",
          "mustExpose": [
            "enterprise base URL",
            "GitHub App manifest setup URLs"
          ],
          "expectedProvisioning": [
            "setup URLs use enterprise host",
            "manifest exchange uses /api/v3"
          ]
        },
        {
          "id": "gitlab-dot-com",
          "provider": "gitlab",
          "host": "gitlab.com",
          "auth": "manual-token",
          "mustExpose": [
            "GitLab token password input"
          ],
          "expectedProvisioning": [
            "manual-token",
            "manual-token-required",
            "secret key token"
          ]
        },
        {
          "id": "self-managed-gitlab",
          "provider": "gitlab",
          "host": "custom",
          "auth": "gitlab-instance-oauth-app",
          "mustExpose": [
            "GitLab base URL",
            "admin applications endpoint"
          ],
          "expectedProvisioning": [
            "/api/v4/applications",
            "webhooks disabled by default"
          ]
        }
      ],
      "mediaFolder": "04_source"
    },
    {
